{
  "name": "ai-sme-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:with-db": "npm run db:up && npm run dev",
    "build": "next build",
    "vercel-build": "prisma migrate deploy && prisma generate && npm run db:seed && next build",
    "analyze": "cross-env ANALYZE=true next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:ui-imports": "node scripts/check-ui-imports.mjs",
    "check:architecture": "node scripts/check-architecture.mjs",
    "ci:verify": "npm run check:ui-imports && npm run check:architecture && npm run lint && npm run typecheck && npm run test && npm run build",
    "postinstall": "prisma generate",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose stop db",
    "db:push": "prisma db push --skip-generate",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "ts-node --project prisma/tsconfig.seed.json prisma/seed.ts",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "6.19.2",
    "@tanstack/react-query": "^5.91.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "14.2.35",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "openai": "6.32.0",
    "prisma": "6.19.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "20.19.18",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.4.21",
    "cross-env": "^10.1.0",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  }
}
